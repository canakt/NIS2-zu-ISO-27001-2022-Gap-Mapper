<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>NIS2 → ISO 27001:2022 Gap-Report</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Segoe UI', Arial, sans-serif;
      background: #f4f6f9;
      color: #1a1a2e;
      font-size: 14px;
    }
    header {
      background: linear-gradient(135deg, #1a1a2e 0%, #16213e 60%, #0f3460 100%);
      color: #fff;
      padding: 36px 48px;
    }
    header h1 { font-size: 26px; font-weight: 700; letter-spacing: .5px; }
    header .meta { margin-top: 12px; opacity: .85; font-size: 13px; }
    .summary-bar {
      display: flex;
      gap: 20px;
      padding: 20px 48px;
      background: #fff;
      border-bottom: 1px solid #e0e4ea;
      flex-wrap: wrap;
    }
    .kpi {
      flex: 1 1 160px;
      background: #f4f6f9;
      border-radius: 8px;
      padding: 14px 20px;
      text-align: center;
    }
    .kpi .val { font-size: 30px; font-weight: 800; }
    .kpi .lbl { font-size: 11px; text-transform: uppercase; letter-spacing: .6px; color: #666; margin-top: 4px; }
    .kpi.green .val { color: #2e7d32; }
    .kpi.yellow .val { color: #e65100; }
    .kpi.red .val { color: #c62828; }
    .kpi.blue .val { color: #1565c0; }

    main { padding: 32px 48px; }
    section.req-block {
      background: #fff;
      border-radius: 10px;
      box-shadow: 0 1px 4px rgba(0,0,0,.08);
      margin-bottom: 24px;
      overflow: hidden;
    }
    .req-header {
      display: flex;
      align-items: flex-start;
      gap: 16px;
      padding: 18px 24px;
      border-bottom: 1px solid #e8eaed;
    }
    .badge {
      display: inline-block;
      padding: 5px 14px;
      border-radius: 20px;
      font-weight: 700;
      font-size: 12px;
      white-space: nowrap;
      min-width: 90px;
      text-align: center;
      flex-shrink: 0;
    }
    .badge-erfuellt  { background: #e8f5e9; color: #2e7d32; border: 1px solid #a5d6a7; }
    .badge-teilweise { background: #fff3e0; color: #e65100; border: 1px solid #ffcc80; }
    .badge-luecke    { background: #ffebee; color: #c62828; border: 1px solid #ef9a9a; }
    .req-title { font-weight: 700; font-size: 15px; }
    .req-desc  { font-size: 12px; color: #555; margin-top: 3px; }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
    }
    thead th {
      background: #2e4057;
      color: #fff;
      padding: 9px 14px;
      text-align: left;
      font-weight: 600;
      letter-spacing: .3px;
    }
    tbody tr:nth-child(even) { background: #f9fafb; }
    tbody td { padding: 8px 14px; border-bottom: 1px solid #e8eaed; vertical-align: top; }
    .status-pill {
      display: inline-block;
      padding: 3px 12px;
      border-radius: 12px;
      font-size: 11.5px;
      font-weight: 600;
      white-space: nowrap;
    }
    .s-umgesetzt  { background: #e8f5e9; color: #2e7d32; }
    .s-teilweise  { background: #fff3e0; color: #e65100; }
    .s-nicht      { background: #ffebee; color: #c62828; }
    .s-unbekannt  { background: #eceff1; color: #546e7a; }

    .summary-table { margin-top: 40px; }
    .summary-table h2 { font-size: 18px; margin-bottom: 16px; }
    .summary-table table { border-radius: 8px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,.1); }

    footer {
      text-align: center;
      padding: 24px;
      color: #999;
      font-size: 12px;
    }
  </style>
</head>
<body>

<header>
  <h1>NIS2 Art. 21 → ISO 27001:2022 Gap-Report</h1>
  <div class="meta">Erstellt am {{ datum }} &nbsp;|&nbsp; Gesamterfüllungsquote: <strong>{{ gesamt_quote }} %</strong></div>
</header>

<div class="summary-bar">
  <div class="kpi blue">
    <div class="val">{{ gesamt_total }}</div>
    <div class="lbl">NIS2-Anforderungen</div>
  </div>
  <div class="kpi green">
    <div class="val">{{ gesamt_erfuellt }}</div>
    <div class="lbl">Erfüllt</div>
  </div>
  <div class="kpi yellow">
    <div class="val">{{ gesamt_teilweise }}</div>
    <div class="lbl">Teilweise erfüllt</div>
  </div>
  <div class="kpi red">
    <div class="val">{{ gesamt_luecken }}</div>
    <div class="lbl">Lücken</div>
  </div>
  <div class="kpi blue">
    <div class="val">{{ gesamt_quote }} %</div>
    <div class="lbl">Gesamtquote</div>
  </div>
</div>

<main>

  {% for req_name, result in results.items() %}
  <section class="req-block">
    <div class="req-header">
      {% if result.rag == "Erfüllt" %}
        <span class="badge badge-erfuellt">✓ Erfüllt</span>
      {% elif result.rag == "Teilweise" %}
        <span class="badge badge-teilweise">~ Teilweise</span>
      {% else %}
        <span class="badge badge-luecke">✗ Lücke</span>
      {% endif %}
      <div>
        <div class="req-title">{{ req_name }}</div>
        <div class="req-desc">{{ result.beschreibung }}</div>
      </div>
    </div>
    <table>
      <thead>
        <tr>
          <th>Control-ID</th>
          <th>Control-Name</th>
          <th>Status</th>
          <th>Verantwortlich</th>
          <th>Notizen</th>
        </tr>
      </thead>
      <tbody>
        {% for ctrl in result.controls %}
        <tr>
          <td><strong>{{ ctrl.control_id }}</strong></td>
          <td>{{ ctrl.control_name }}</td>
          <td>
            {% if ctrl.status == "Umgesetzt" %}
              <span class="status-pill s-umgesetzt">{{ ctrl.status }}</span>
            {% elif ctrl.status == "Teilweise" %}
              <span class="status-pill s-teilweise">{{ ctrl.status }}</span>
            {% elif ctrl.status == "Nicht umgesetzt" %}
              <span class="status-pill s-nicht">{{ ctrl.status }}</span>
            {% else %}
              <span class="status-pill s-unbekannt">{{ ctrl.status }}</span>
            {% endif %}
          </td>
          <td>{{ ctrl.responsible }}</td>
          <td>{{ ctrl.notes }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </section>
  {% endfor %}

  <div class="summary-table">
    <h2>Zusammenfassung – alle NIS2-Anforderungen</h2>
    <table>
      <thead>
        <tr>
          <th>NIS2-Anforderung</th>
          <th>Status</th>
          <th>Erfüllt</th>
          <th>Teilweise</th>
          <th>Gesamt</th>
        </tr>
      </thead>
      <tbody>
        {% for req_name, result in results.items() %}
        <tr>
          <td>{{ req_name }}</td>
          <td>
            {% if result.rag == "Erfüllt" %}
              <span class="badge badge-erfuellt">✓ Erfüllt</span>
            {% elif result.rag == "Teilweise" %}
              <span class="badge badge-teilweise">~ Teilweise</span>
            {% else %}
              <span class="badge badge-luecke">✗ Lücke</span>
            {% endif %}
          </td>
          <td>{{ result.umgesetzt }}</td>
          <td>{{ result.teilweise }}</td>
          <td>{{ result.total }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

</main>

<footer>
  NIS2 → ISO 27001:2022 Gap-Mapper &nbsp;|&nbsp; {{ datum }}
</footer>

</body>
</html>
